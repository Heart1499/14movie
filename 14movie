<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>小雨披大导演 · 锐因九号房</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: #0a0705;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: system-ui, -apple-system, 'Segoe UI', monospace;
            padding: 16px;
        }

        .control-room {
            max-width: 1400px;
            width: 100%;
            background: #11100e;
            border-radius: 40px;
            box-shadow: 0 30px 50px rgba(0,0,0,0.6), 0 0 0 1px #4a3524 inset;
            overflow: hidden;
        }

        .camera-wall {
            background: #050403;
            padding: 20px 24px 16px;
            border-bottom: 2px solid #b87c4a;
        }

        .cam-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            color: #bfa98e;
            font-size: 12px;
            letter-spacing: 1px;
        }

        .live-dot {
            display: inline-block;
            width: 10px;
            height: 10px;
            background: #e34d4d;
            border-radius: 50%;
            box-shadow: 0 0 8px red;
            margin-right: 8px;
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0% { opacity: 0.5; transform: scale(0.8);}
            100% { opacity: 1; transform: scale(1);}
        }

        .room-preview {
            background: #0c0a08;
            border-radius: 32px;
            padding: 20px;
            border: 1px solid #36281d;
        }

        .characters-area {
            display: flex;
            justify-content: center;
            gap: 50px;
            flex-wrap: wrap;
            margin: 10px 0 20px;
        }

        .char-card {
            background: #201a14;
            border-radius: 60px;
            padding: 12px 24px;
            display: flex;
            align-items: center;
            gap: 16px;
            box-shadow: 0 6px 0 #0b0805;
            border-bottom: 2px solid #d6955a;
        }

        .char-icon {
            width: 56px;
            height: 56px;
            background: #3f2c1d;
            border-radius: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
        }

        .char-name {
            color: #f3cf9a;
            font-weight: bold;
            font-size: 18px;
        }

        .char-tag {
            font-size: 12px;
            color: #b49470;
        }

        /* 状态条区域 - 加大显示 */
        .stats-area {
            background: #1f1914;
            border-radius: 30px;
            padding: 16px 20px;
            margin-top: 16px;
        }

        .stat-row {
            margin-bottom: 12px;
        }

        .stat-label {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: #e2bc89;
            margin-bottom: 6px;
        }

        .stat-bar-bg {
            background: #2a241f;
            height: 12px;
            border-radius: 20px;
            overflow: hidden;
        }

        .stat-bar-fill {
            height: 100%;
            border-radius: 20px;
            transition: width 0.2s;
        }

        .fill-s {
            background: #d97838;
        }
        .fill-h {
            background: #c96f5e;
        }
        .fill-escape {
            background: #4c9f70;
        }

        .stat-value {
            font-family: monospace;
            font-weight: bold;
        }

        .cmd-count-badge {
            background: #2c241e;
            display: inline-block;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 11px;
            margin-top: 8px;
        }

        .action-log {
            background: #0d0b09;
            margin: 18px 20px 20px 20px;
            border-radius: 24px;
            padding: 14px 18px;
            color: #d7cdbc;
            font-size: 12px;
            font-family: monospace;
            border-left: 5px solid #d78c45;
            min-height: 150px;
            max-height: 180px;
            overflow-y: auto;
        }

        .director-console {
            background: #1a1511;
            padding: 20px 24px 28px;
        }

        .section-title {
            font-size: 18px;
            font-weight: bold;
            color: #e7bc82;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-left: 3px solid #e2a15b;
            padding-left: 14px;
        }

        .command-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 24px;
            max-height: 280px;
            overflow-y: auto;
            padding-bottom: 8px;
        }

        .cmd-btn {
            background: #2c221b;
            border: 1px solid #745d45;
            color: #ffefdb;
            padding: 8px 14px;
            border-radius: 60px;
            font-family: monospace;
            font-weight: bold;
            font-size: 12px;
            cursor: pointer;
            flex: 1 0 auto;
            min-width: 85px;
            text-align: center;
            transition: 0.05s linear;
        }

        .cmd-btn:active {
            background: #4e3725;
            transform: scale(0.96);
        }

        /* 导演互动区 */
        .director-interact {
            background: #2a221c;
            border-radius: 28px;
            padding: 16px;
            margin: 16px 0 20px;
            border: 1px solid #594f43;
        }

        .interact-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 16px;
        }

        .interact-btn {
            background: #3d2c1f;
            border: none;
            padding: 8px 14px;
            border-radius: 40px;
            color: #f0cfaa;
            font-size: 12px;
            cursor: pointer;
            font-family: monospace;
        }

        .interact-btn:active {
            background: #5e402c;
        }

        .talk-input-area {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 8px;
        }

        .talk-input {
            flex: 1;
            background: #1a1511;
            border: 1px solid #6a5642;
            border-radius: 60px;
            padding: 10px 16px;
            color: #f0e2d0;
            font-family: monospace;
            font-size: 13px;
            outline: none;
        }

        .send-btn {
            background: #4f3824;
            border: none;
            padding: 8px 20px;
            border-radius: 60px;
            color: white;
            cursor: pointer;
            font-family: monospace;
            font-weight: bold;
        }

        .progress-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-top: 8px;
        }

        .reset-btn {
            background: #4f3824;
            border: none;
            padding: 6px 20px;
            border-radius: 40px;
            color: white;
            cursor: pointer;
            font-family: monospace;
        }

        .ending-box {
            background: #221c16e0;
            backdrop-filter: blur(12px);
            border-radius: 36px;
            padding: 28px;
            text-align: center;
            margin: 20px 0;
            border: 1px solid #e5a362;
        }

        .share-hint {
            background: #2e241d;
            border-radius: 28px;
            padding: 10px 16px;
            margin-top: 16px;
            font-size: 11px;
            color: #b9a78e;
            text-align: center;
            cursor: pointer;
        }

        .badge-area {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-top: 12px;
            flex-wrap: wrap;
        }

        .ending-badge {
            background: #3d2c1f;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 11px;
        }

        @media (max-width: 700px) {
            .char-card { padding: 8px 16px; gap: 10px;}
            .cmd-btn { font-size: 10px; padding: 6px 10px; min-width: 70px;}
            .interact-btn { font-size: 10px; padding: 6px 12px;}
            .talk-input { font-size: 11px; padding: 8px 12px;}
        }
    </style>
</head>
<body>
<div class="control-room" id="appRoot">
    <div class="camera-wall">
        <div class="cam-header">
            <span><span class="live-dot"></span> 九号房 · 封闭监控</span>
            <span>小雨披大导演</span>
        </div>
        <div class="room-preview">
            <div class="characters-area">
                <div class="char-card">
                    <div class="char-icon">🦒</div>
                    <div><div class="char-name">申惟</div><div class="char-tag">队长 · 年上克制 · 易红温</div></div>
                </div>
                <div class="char-card">
                    <div class="char-icon">🐰</div>
                    <div><div class="char-name">韩振</div><div class="char-tag">中国弟 · 推拉 · 爱逗哥哥</div></div>
                </div>
            </div>
            
            <!-- 可视化状态条 -->
            <div class="stats-area">
                <div class="stat-row">
                    <div class="stat-label"><span>🔥 申惟忍耐值</span><span id="tensionS_val" class="stat-value">68</span><span>%</span></div>
                    <div class="stat-bar-bg"><div class="stat-bar-fill fill-s" id="tensionS_bar" style="width:68%"></div></div>
                </div>
                <div class="stat-row">
                    <div class="stat-label"><span>💗 韩振羞耻值</span><span id="tensionH_val" class="stat-value">65</span><span>%</span></div>
                    <div class="stat-bar-bg"><div class="stat-bar-fill fill-h" id="tensionH_bar" style="width:65%"></div></div>
                </div>
                <div class="stat-row">
                    <div class="stat-label"><span>🔓 逃脱进度</span><span id="escape_val" class="stat-value">0</span><span>%</span></div>
                    <div class="stat-bar-bg"><div class="stat-bar-fill fill-escape" id="escape_bar" style="width:0%"></div></div>
                </div>
                <div class="cmd-count-badge" id="cmdCountDisplay">🎬 已执行指令: 0</div>
            </div>
        </div>
        <div class="action-log" id="actionLog">
            📼 系统: 九号房规则——亲密值达标才能开门。导演请下达指令。
        </div>
    </div>
    <div class="director-console" id="directorConsole"></div>
</div>

<script>
    (function() {
        // 游戏状态
        let tensionS = 68;
        let tensionH = 65;
        let escape = 0;
        let gameActive = true;
        let ended = false;
        let logs = [];
        let lastCommandDesc = "";
        let cmdCount = 0;
        let finalEndingType = null;

        // 事故计数器
        let accidentCount = 0;

        function updateUI() {
            document.getElementById('tensionS_val') && (document.getElementById('tensionS_val').innerText = Math.floor(tensionS));
            document.getElementById('tensionH_val') && (document.getElementById('tensionH_val').innerText = Math.floor(tensionH));
            document.getElementById('escape_val') && (document.getElementById('escape_val').innerText = Math.floor(escape));
            document.getElementById('tensionS_bar') && (document.getElementById('tensionS_bar').style.width = Math.min(100, tensionS) + '%');
            document.getElementById('tensionH_bar') && (document.getElementById('tensionH_bar').style.width = Math.min(100, tensionH) + '%');
            document.getElementById('escape_bar') && (document.getElementById('escape_bar').style.width = Math.min(100, escape) + '%');
            document.getElementById('cmdCountDisplay') && (document.getElementById('cmdCountDisplay').innerText = `🎬 已执行指令: ${cmdCount}`);
        }

        function addLog(msg) {
            logs.unshift(msg);
            if(logs.length > 14) logs.pop();
            const logDiv = document.getElementById('actionLog');
            if(logDiv) {
                logDiv.innerHTML = logs.map((l, i) => (i === 0 ? "🎬 " : "&nbsp;&nbsp;") + l).join('<br>');
            }
        }

        // 检查事故：进度太慢或紧张值过高可能触发事故
        function checkAccident() {
            if(ended || escape >= 100) return false;
            // 事故条件：指令数>8且逃脱进度<30 且紧张值都>60
            if(cmdCount > 8 && escape < 30 && tensionS > 60 && tensionH > 60 && accidentCount < 2) {
                accidentCount++;
                let accidentMsg = "";
                let rand = Math.floor(Math.random() * 4);
                if(rand === 0) accidentMsg = "💥 事故: 申惟太紧张撞到了桌角，两人尴尬地分开了一会儿。气氛更僵了。(紧张值+5)";
                else if(rand === 1) accidentMsg = "💥 事故: 韩振想靠近结果被地毯绊了一下，申惟伸手扶住但两人都摔倒在地。尴尬值上升了。";
                else if(rand === 2) accidentMsg = "💥 事故: 房间灯突然闪烁，两人吓了一跳，好不容易缓和的气氛又变冷了。(紧张值+4)";
                else accidentMsg = "💥 事故: 韩振不小心把水打翻在申惟身上，手忙脚乱去擦反而更尴尬了。";
                tensionS = Math.min(95, tensionS + 5);
                tensionH = Math.min(95, tensionH + 4);
                addLog(accidentMsg);
                updateUI();
                return true;
            }
            // 另一种事故：过于紧张导致逃避行为
            if(cmdCount > 5 && tensionS > 75 && Math.random() < 0.15 && accidentCount < 2) {
                accidentCount++;
                addLog("💥 事故: 申惟实在顶不住，躲到房间角落背对着韩振。韩振站在原地不知所措。房门纹丝不动。");
                tensionS = Math.min(96, tensionS + 3);
                updateUI();
                return true;
            }
            return false;
        }

        // 导演自由发言 + 额外行动
        function directorAction(actionType, customText = "") {
            if(!gameActive || escape >= 100) {
                addLog("导演话筒没声了，房间已经解锁或者游戏结束。重置再喊话吧。");
                return;
            }
            switch(actionType) {
                case "shout":
                    if(!customText) return;
                    addLog(`【导演喊话】“${customText}”`);
                    if(customText.includes("亲") || customText.includes("吻") || customText.includes("抱") || customText.includes("摸")) {
                        tensionS = Math.max(10, tensionS - 3);
                        tensionH = Math.max(10, tensionH - 3);
                        addLog(`  导演的话让两人心跳加速，紧张值略微下降。`);
                    } else if(customText.includes("快") || customText.includes("速度")) {
                        let extra = Math.floor(Math.random() * 5) + 2;
                        escape = Math.min(100, escape + extra);
                        addLog(`  导演催进度，房门松动了一点 +${extra}%`);
                    } else if(customText.includes("尴尬")) {
                        tensionS = Math.min(95, tensionS + 4);
                        tensionH = Math.min(95, tensionH + 3);
                        addLog(`  导演提到尴尬，两人更不自在了。`);
                    } else if(customText.includes("加油") || customText.includes("努力")) {
                        let extra = Math.floor(Math.random() * 4) + 1;
                        escape = Math.min(100, escape + extra);
                        addLog(`  导演的鼓励让两人更有动力 +${extra}%`);
                    } else {
                        addLog(`  导演的话在房间里回荡，两人沉默了几秒。`);
                    }
                    break;
                case "music":
                    addLog(`【导演】打开了房间音响，播放了抒情歌。`);
                    tensionS = Math.max(10, tensionS - 4);
                    tensionH = Math.max(10, tensionH - 3);
                    addLog(`  音乐让气氛柔和了一些，紧张值下降。`);
                    break;
                case "light":
                    addLog(`【导演】把灯光调暗了。`);
                    tensionS = Math.max(10, tensionS - 2);
                    tensionH = Math.max(10, tensionH - 5);
                    addLog(`  昏暗的光线下，两人似乎没那么紧绷了。`);
                    break;
                case "coffee":
                    addLog(`【导演】通过传送口送了两杯咖啡进去。`);
                    tensionS = Math.max(10, tensionS - 3);
                    tensionH = Math.max(10, tensionH - 2);
                    addLog(`  申惟和韩振默默喝咖啡，气氛缓和了一点。`);
                    break;
                case "snack":
                    addLog(`【导演】送了一盘零食进去。`);
                    tensionH = Math.max(10, tensionH - 4);
                    addLog(`  韩振拿了一块递向申惟，申惟犹豫了一下接过来了。`);
                    break;
                default: return;
            }
            updateUI();
            checkAccident();
            if(escape >= 100 && !ended) checkEnding();
        }

        function directorSay(text) {
            directorAction("shout", text);
        }

        function checkEnding() {
            if(escape >= 100 && !ended) {
                escape = 100;
                determineEnding();
                showEnding();
            }
        }

        // 丰富结局判定
        function determineEnding() {
            if(escape >= 100) {
                if(tensionS <= 25 && tensionH <= 28) finalEndingType = "perfect";
                else if(tensionS <= 38 && tensionH <= 40) finalEndingType = "sweet";
                else if(tensionS >= 65 || tensionH >= 68) finalEndingType = "awkward";
                else if(cmdCount >= 20) finalEndingType = "long";
                else if(tensionS >= 50 && tensionH >= 50) finalEndingType = "cold";
                else finalEndingType = "normal";
            } else {
                // 未逃脱但游戏结束的情况（理论上不会，但兜底）
                finalEndingType = "stuck";
            }
        }

        function getEndingMessage() {
            switch(finalEndingType) {
                case "perfect":
                    return "房门自动打开。申惟牵着韩振的手走出来，韩振眼角有点红但嘴角是笑着的。申惟转头看他，忽然也笑了。之后团综里两人对视不再躲闪，粉丝发现申惟的手机壳换成了韩振送的那款。导演你促成了真正的亲密。";
                case "sweet":
                    return "门开了。申惟帮韩振把衣服整理好，韩振小声说了句谢谢哥。两人一前一后走出去，但申惟的手一直往后伸，直到韩振握住。不算轰轰烈烈，但所有人都看得出有什么不一样了。";
                case "awkward":
                    return "门终于开了。申惟快步走在前面，韩振跟在后面低着头。出来后两人还是别扭，但粉丝拍到机场申惟帮韩振拉了拉口罩，韩振偷偷笑了。暧昧持久战，但更真了。";
                case "long":
                    return "经过漫长的拉扯，房门在一声轻响后打开。两人都愣住了，好像还没习惯。申惟先回过神来，把外套递给韩振。那天之后，他们的互动多了些心照不宣的默契。";
                case "cold":
                    return "门开了。两人沉默着走出去，没有牵手也没有对话。但晚上直播时韩振说“申惟哥今天帮我拿了行李”，申惟在旁边耳朵红了。有些东西不说破，但都在。";
                case "stuck":
                    return "折腾了半天，房门纹丝不动。两人瘫坐在地上，申惟叹了口气说“我们是不是太不熟了”。韩振笑了，说“那哥要不要试着多了解我一点”。门突然响了一下——也许还需要一点时间。";
                default:
                    return "房间解锁。申惟把外套披在韩振身上，两人并排走出去，肩膀偶尔碰到也没有躲。没有轰轰烈烈，但所有人都看得出有什么不一样了。";
            }
        }

        function getEndingTitle() {
            switch(finalEndingType) {
                case "perfect": return "天作之合 · 双向奔赴";
                case "sweet": return "细水长流 · 温柔以待";
                case "awkward": return "推拉美学 · 暧昧至上";
                case "long": return "日久生情 · 马拉松式心动";
                case "cold": return "口是心非 · 暗涌";
                case "stuck": return "未完待续 · 还需要努力";
                default: return "破冰之旅 · 新的开始";
            }
        }

        function executeCommand(cmdId) {
            if(!gameActive) { addLog("游戏已结束，请按重新开拍。"); return; }
            if(escape >= 100) { addLog("房间已解锁，不用再指令。按重新开拍继续导演。"); return; }

            cmdCount++;
            let deltaS = 0, deltaH = 0, deltaEsc = 0;
            let flavorText = "";
            let transitionText = lastCommandDesc ? "（承接上一轮）" : "";

            switch(cmdId) {
                case "kiss_deep":
                    addLog("指令: 深吻三十秒");
                    deltaS = -10; deltaH = -9; deltaEsc = 6+Math.floor(Math.random()*6);
                    flavorText = "韩振踮起脚尖，申惟愣了一秒后低头回应。分开时两人都在喘，韩振耳朵红到脖子根，申惟手指还搭在他腰上没松开。";
                    break;
                case "neck_bite":
                    addLog("指令: 喉结轻咬");
                    deltaS = -12; deltaH = -7; deltaEsc = 7+Math.floor(Math.random()*6);
                    flavorText = "韩振凑过去轻轻咬住申惟喉结，申惟闷哼一声仰起头，手指攥紧了韩振的衣服。韩振松口后看到浅浅的牙印，伸手摸了摸。";
                    break;
                case "lap_grind":
                    addLog("指令: 腿上磨蹭");
                    deltaS = -14; deltaH = -11; deltaEsc = 8+Math.floor(Math.random()*7);
                    flavorText = "韩振跨坐在申惟腿上，缓慢磨蹭。申惟手不知道该放哪，最后扣住韩振的腰，韩振把脸埋进他肩膀，声音闷闷的。";
                    break;
                case "shirt_off":
                    addLog("指令: 脱上衣");
                    deltaS = -9; deltaH = -13; deltaEsc = 7+Math.floor(Math.random()*6);
                    flavorText = "申惟帮韩振脱掉上衣，指尖碰到皮肤时韩振抖了一下，申惟动作突然变慢，像是在描摹。";
                    break;
                case "wall_press":
                    addLog("指令: 壁咚");
                    deltaS = -8; deltaH = -10; deltaEsc = 6+Math.floor(Math.random()*5);
                    flavorText = "申惟把韩振按在墙上，单手撑头。韩振拽住他的衣领拉近，两人鼻尖快碰到时申惟偏过头，呼吸全落在韩振耳侧。";
                    break;
                case "ear_whisper_ch":
                    addLog("指令: 中文耳语");
                    deltaS = -11; deltaH = -8; deltaEsc = 6+Math.floor(Math.random()*6);
                    flavorText = "韩振凑过去轻声说“哥想不想更过分一点”，申惟耳朵瞬间血红，过了好几秒才找回声音:“……别说这种话。”";
                    break;
                case "blindfold":
                    addLog("指令: 蒙眼描摹");
                    deltaS = -15; deltaH = -6; deltaEsc = 9+Math.floor(Math.random()*6);
                    flavorText = "蒙住申惟眼睛，韩振用手指描摹他的脸。申惟失去视觉后触觉放大，指尖划过嘴唇时他轻颤了一下。";
                    break;
                case "thigh_rub":
                    addLog("指令: 大腿蹭");
                    deltaS = -16; deltaH = -14; deltaEsc = 10+Math.floor(Math.random()*7);
                    flavorText = "韩振用大腿蹭申惟腿间，申惟抓住他的腿想阻止又没用力，呼吸彻底乱了。";
                    break;
                case "back_hug_chest":
                    addLog("指令: 背后抱胸");
                    deltaS = -10; deltaH = -11; deltaEsc = 7+Math.floor(Math.random()*5);
                    flavorText = "申惟从背后抱住韩振，手放在他胸口。韩振按住他的手不让拿开，两个人像连体婴一样贴在一起。";
                    break;
                case "floor_press":
                    addLog("指令: 地板压制");
                    deltaS = -11; deltaH = -10; deltaEsc = 8+Math.floor(Math.random()*6);
                    flavorText = "两人滚到地板上，申惟在上方俯视韩振。韩振抬手摸了摸申惟的脸，申惟闭上眼睛，把脸埋进韩振颈窝。";
                    break;
                case "belt_remove":
                    addLog("指令: 解皮带");
                    deltaS = -17; deltaH = -12; deltaEsc = 11+Math.floor(Math.random()*7);
                    flavorText = "韩振解开申惟的皮带，金属扣碰撞的声音在房间里格外响。申惟呼吸一滞，握住了韩振的手却又慢慢松开。";
                    break;
                case "hand_down":
                    addLog("指令: 手探裤腰");
                    deltaS = -15; deltaH = -17; deltaEsc = 10+Math.floor(Math.random()*7);
                    flavorText = "申惟的手从韩振腰侧滑进裤腰，韩振轻哼了一声，申惟立刻停住，韩振却按着他的手不放。";
                    break;
                case "missionary":
                    addLog("指令: 传教士");
                    deltaS = -18; deltaH = -16; deltaEsc = 12+Math.floor(Math.random()*7);
                    flavorText = "申惟把韩振压在床上，膝盖顶开他双腿。韩振勾住申惟的脖子，把最后一点距离也吞没了。";
                    break;
                case "spoon":
                    addLog("指令: 汤匙抱");
                    deltaS = -9; deltaH = -8; deltaEsc = 5+Math.floor(Math.random()*5);
                    flavorText = "申惟从背后环住韩振的腰，下巴抵着他后脑勺，安静地抱了很久，心跳却越来越快。";
                    break;
                case "teasing_deny":
                    addLog("指令: 逗弄不许碰");
                    deltaS = -6; deltaH = -5; deltaEsc = 4+Math.floor(Math.random()*4);
                    flavorText = "韩振逗申惟但不让他碰，申惟急了，一把拽回来小声说“别闹了”，韩振愣了一下发现申惟眼眶有点红。";
                    break;
                case "praise_kink":
                    addLog("指令: 边亲边夸");
                    deltaS = -8; deltaH = -10; deltaEsc = 7+Math.floor(Math.random()*5);
                    flavorText = "申惟边亲韩振边夸他“做得真好”，韩振把脸埋进申惟胸口，闷闷地说“哥别说了”。";
                    break;
                case "hair_pull":
                    addLog("指令: 揪头发吻");
                    deltaS = -10; deltaH = -7; deltaEsc = 7+Math.floor(Math.random()*5);
                    flavorText = "韩振揪着申惟后脑头发接吻，申惟吃痛反而吻得更用力。分开时申惟嘴唇红红的，韩振帮他理了理被揪乱的头发。";
                    break;
                case "table_edge":
                    addLog("指令: 书桌边缘");
                    deltaS = -12; deltaH = -11; deltaEsc = 9+Math.floor(Math.random()*6);
                    flavorText = "申惟把韩振抱上书桌边缘，韩振双腿夹住他的腰，桌面上的东西被扫到一边。";
                    break;
                case "knee_ride":
                    addLog("指令: 跪姿仰视");
                    deltaS = -10; deltaH = -13; deltaEsc = 8+Math.floor(Math.random()*6);
                    flavorText = "韩振跪在床上仰头看申惟，从下往上的眼神让申惟喉结一紧，伸手把他拉起来，两个人一起摔进枕头里。";
                    break;
                case "aftercare":
                    addLog("指令: 事后安抚");
                    deltaS = -6; deltaH = -7; deltaEsc = 4+Math.floor(Math.random()*4);
                    flavorText = "申惟帮韩振擦汗，轻声问他疼不疼。韩振摇头又点头，申惟亲了亲他额头。韩振把脸往申惟掌心蹭了蹭。";
                    break;
                default: return;
            }

            tensionS = Math.min(98, Math.max(5, tensionS + deltaS));
            tensionH = Math.min(98, Math.max(5, tensionH + deltaH));
            escape = Math.min(100, escape + deltaEsc);
            
            addLog(`${transitionText} ${flavorText} (申惟${deltaS>=0?'+':''}${deltaS}, 韩振${deltaH>=0?'+':''}${deltaH} | 逃脱+${deltaEsc}%)`);
            
            lastCommandDesc = flavorText.substring(0, 45);
            updateUI();
            
            // 彩蛋和事故检查
            if(cmdCount % 5 === 0 && escape < 90 && !ended) {
                let extra = 3;
                escape = Math.min(100, escape + extra);
                addLog(`✨ 连续指导，两人的默契悄然生长。房门松动 +${extra}%`);
                updateUI();
            }
            if(tensionS < 30 && tensionH < 32 && escape < 90 && !ended) {
                let extra = 6;
                escape = Math.min(100, escape + extra);
                addLog(`💘 两人不约而同看向对方，然后同时笑了。门锁咔哒一声 +${extra}%`);
                updateUI();
            }
            
            checkAccident();
            
            if(escape >= 100 && !ended) {
                determineEnding();
                showEnding();
            }
            updateUI();
        }

        function showEnding() {
            ended = true;
            gameActive = false;
            const endingTitle = getEndingTitle();
            const endingMsg = getEndingMessage();
            
            const consoleDiv = document.getElementById('directorConsole');
            if(consoleDiv) {
                consoleDiv.innerHTML = `
                    <div class="ending-box">
                        <div style="font-size: 44px;">🔓</div>
                        <h2 style="color:#eebb77; margin: 10px 0;">${endingTitle}</h2>
                        <p style="color:#efdbbc; margin: 16px 0; line-height:1.5;">${endingMsg}</p>
                        <div class="badge-area">
                            <span class="ending-badge">🔥 申惟: ${Math.floor(tensionS)}%</span>
                            <span class="ending-badge">💗 韩振: ${Math.floor(tensionH)}%</span>
                            <span class="ending-badge">🎬 指令数: ${cmdCount}</span>
                            <span class="ending-badge">💥 事故次数: ${accidentCount}</span>
                        </div>
                        <div class="share-hint" id="copyEndingBtn">📸 点击复制结局，分享到豆瓣/微博</div>
                        <button class="reset-btn" id="resetEndBtn" style="background:#b46f3a; margin-top:16px; padding:10px 26px;">🎬 重新开拍</button>
                    </div>
                    <div class="progress-row" style="margin-top:18px;">
                        <div class="escape-bar"><div class="escape-fill" style="width:100%"></div></div>
                        <button class="reset-btn" id="resetEndBtn2">重置</button>
                    </div>
                `;
                const reset1 = document.getElementById('resetEndBtn');
                const reset2 = document.getElementById('resetEndBtn2');
                const copyBtn = document.getElementById('copyEndingBtn');
                const resetFunc = () => resetGame();
                if(reset1) reset1.addEventListener('click', resetFunc);
                if(reset2) reset2.addEventListener('click', resetFunc);
                if(copyBtn) {
                    copyBtn.addEventListener('click', () => {
                        const shareText = `【小雨披大导演】锐因九号房结局达成！\n结局: ${endingTitle}\n${endingMsg}\n申惟${Math.floor(tensionS)}% 韩振${Math.floor(tensionH)}% 共执行${cmdCount}个指令 事故${accidentCount}次\n玩到这里，我的导演心得: 锐因是真的。`;
                        navigator.clipboard.writeText(shareText).then(() => {
                            copyBtn.innerText = "✓ 已复制，去发帖吧！";
                            setTimeout(() => { copyBtn.innerText = "📸 点击复制结局，分享到豆瓣/微博"; }, 2000);
                        });
                    });
                }
            }
            updateUI();
        }

        function resetGame() {
            tensionS = 68;
            tensionH = 65;
            escape = 0;
            gameActive = true;
            ended = false;
            logs = [];
            lastCommandDesc = "";
            cmdCount = 0;
            accidentCount = 0;
            finalEndingType = null;
            
            const consoleDiv = document.getElementById('directorConsole');
            if(consoleDiv) {
                consoleDiv.innerHTML = `
                    <div class="section-title">
                        🎙️ 指令台 · 让锐因完成任务
                    </div>
                    <div class="command-grid" id="commandGrid"></div>
                    <div class="director-interact">
                        <div class="talk-label">🎙️ 导演工具箱</div>
                        <div class="interact-buttons">
                            <button class="interact-btn" id="musicBtn">🎵 播放音乐</button>
                            <button class="interact-btn" id="lightBtn">💡 调暗灯光</button>
                            <button class="interact-btn" id="coffeeBtn">☕ 送咖啡</button>
                            <button class="interact-btn" id="snackBtn">🍪 送零食</button>
                        </div>
                        <div class="talk-input-area">
                            <input type="text" class="talk-input" id="directorTalkInput" placeholder="直接喊话，比如: 申惟你别躲了 / 韩振再主动一点" autocomplete="off">
                            <button class="send-btn" id="sendTalkBtn">喊话</button>
                        </div>
                    </div>
                    <div class="progress-row">
                        <div class="escape-bar"><div class="escape-fill" style="width:0%"></div></div>
                        <button class="reset-btn" id="resetGameBtn">🎞️ 重新开拍</button>
                    </div>
                `;
            }
            
            const actions = [
                { id: "kiss_deep", label: "深吻" }, { id: "neck_bite", label: "喉结轻咬" },
                { id: "lap_grind", label: "腿上磨蹭" }, { id: "shirt_off", label: "脱上衣" },
                { id: "wall_press", label: "壁咚" }, { id: "ear_whisper_ch", label: "中文耳语" },
                { id: "blindfold", label: "蒙眼描摹" }, { id: "thigh_rub", label: "大腿蹭" },
                { id: "back_hug_chest", label: "背后抱胸" }, { id: "floor_press", label: "地板压制" },
                { id: "belt_remove", label: "解皮带" }, { id: "hand_down", label: "手探裤腰" },
                { id: "missionary", label: "传教士" }, { id: "spoon", label: "汤匙抱" },
                { id: "teasing_deny", label: "逗弄不许碰" }, { id: "praise_kink", label: "边亲边夸" },
                { id: "hair_pull", label: "揪头发吻" }, { id: "table_edge", label: "书桌边缘" },
                { id: "knee_ride", label: "跪姿仰视" }, { id: "aftercare", label: "事后安抚" }
            ];
            
            const grid = document.getElementById('commandGrid');
            if(grid) {
                actions.forEach(act => {
                    let btn = document.createElement('button');
                    btn.className = "cmd-btn";
                    btn.innerText = act.label;
                    btn.onclick = (function(cmd) { return function() { executeCommand(cmd); }; })(act.id);
                    grid.appendChild(btn);
                });
            }
            
            document.getElementById('musicBtn') && document.getElementById('musicBtn').addEventListener('click', () => directorAction('music'));
            document.getElementById('lightBtn') && document.getElementById('lightBtn').addEventListener('click', () => directorAction('light'));
            document.getElementById('coffeeBtn') && document.getElementById('coffeeBtn').addEventListener('click', () => directorAction('coffee'));
            document.getElementById('snackBtn') && document.getElementById('snackBtn').addEventListener('click', () => directorAction('snack'));
            
            const sendBtn = document.getElementById('sendTalkBtn');
            const talkInput = document.getElementById('directorTalkInput');
            if(sendBtn && talkInput) {
                sendBtn.onclick = () => {
                    let msg = talkInput.value.trim();
                    if(msg) {
                        directorSay(msg);
                        talkInput.value = "";
                    } else {
                        directorSay("导演清了清嗓子，没说话。");
                    }
                };
                talkInput.addEventListener('keypress', (e) => {
                    if(e.key === 'Enter') {
                        let msg = talkInput.value.trim();
                        if(msg) {
                            directorSay(msg);
                            talkInput.value = "";
                        }
                    }
                });
            }
            
            const resetBtn = document.getElementById('resetGameBtn');
            if(resetBtn) resetBtn.addEventListener('click', resetGame);
            
            addLog("🎬 小雨披导演上线。九号房规则: 完成亲密任务才能逃脱。用指令导戏，也可以用工具箱和喊话调整气氛。");
            updateUI();
        }
        
        init();
    })();
</script>
</body>
</html>
